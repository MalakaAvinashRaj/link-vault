# Supabase PostgreSQL — Supavisor transaction pooler (for Vercel serverless)
# Get this from: Supabase Dashboard → Settings → Database → Connection Pooling
# Username format: postgres.[project-ref], Host: aws-[N]-[region].pooler.supabase.com
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-[N]-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Supabase PostgreSQL — direct connection (for Prisma migrations only)
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
